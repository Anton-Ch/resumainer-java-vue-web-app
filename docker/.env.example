# =============================================================================
# ResumAIner — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp docker/.env.example docker/.env
#
# NOTE: .env is in .gitignore — never commit real secrets.
# This .env.example file IS safe to commit (placeholder values only).
# =============================================================================

# --- Database ---
# PostgreSQL password (REQUIRED — no default)
DB_PASSWORD=changeme

# PostgreSQL user (optional — defaults to "resumainer")
DB_USER=resumainer

# PostgreSQL host (for app connection, use "db" when running in Docker)
DB_HOST=db

# PostgreSQL port (optional — defaults to 5432)
DB_PORT=5432

# --- Backend Application ---
# Spring active profile: dev, prod (optional — defaults to prod in Docker)
SPRING_PROFILES_ACTIVE=prod

# Server port (optional — defaults to 8080)
SERVER_PORT=8080

# --- Frontend ---
# Frontend Nginx port (optional — defaults to 80)
FRONTEND_PORT=80
